{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LED AppBar",
  "version": "0.1.0",
  "identifier": "com.katagiri.app-top-bar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png"
    ]
  }
}

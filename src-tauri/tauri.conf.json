{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "app-top-bar",
  "version": "0.1.0",
  "identifier": "com.katagiri.app-top-bar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Top Bar",
        "url": "https://ticker.samoyed.moe/ticker/",
        "width": 1920,
        "height": 80,
        "x": 0,
        "y": 0,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
